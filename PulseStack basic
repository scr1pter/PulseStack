                      <span className="text-amber-500/40 shrink-0 mt-px">
                        &#x2022;
                      </span>
                      {b}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      </div>
    </article>
  );
}

