function FeedCard({ story, index, isBookmarked, onToggleBookmark }) {
  const [loading, setLoading] = useState(false);
  const [bullets, setBullets] = useState([]);
  const [expanded, setExpanded] = useState(false);
  const [error, setError] = useState(false);

  const handleSummarize = async () => {
    if (expanded) {
      setExpanded(false);
      return;
    }
    if (bullets.length > 0) {
      setExpanded(true);
      return;
    }

    setLoading(true);
    setError(false);
    try {
      const result = await generateSummary(story.id, story.title);
      setBullets(result);
      setExpanded(true);
    } catch {
      setError(true);
    } finally {
      setLoading(false);
    }
  };

  const stagger = `stagger-${Math.min(index + 1, 10)}`;

  return (
    <article
      className={cn(
        "animate-fade-up group",
        stagger,
        "bg-zinc-900/50 border border-zinc-800/50 rounded-xl",
        "card-glow mb-4"
      )}
    >
      <div className="p-5">
        <div className="flex items-start gap-4">
          <div className="flex flex-col items-center gap-0.5 pt-0.5 shrink-0">
            <ArrowBigUp className="w-5 h-5 text-orange-400/80" />
            <span className="font-mono text-xs font-medium text-orange-400 tabular-nums">
              {story.score >= 1000
                ? `${(story.score / 1000).toFixed(1)}k`
                : story.score}
            </span>
          </div>

          <div className="flex-1 min-w-0">
            <a
              href={story.url}
              target="_blank"
              rel="noopener noreferrer"
              className="group/link"
            >
              <h2 className="font-display font-semibold text-[15px] leading-snug text-zinc-100 group-hover/link:text-amber-400 transition-colors duration-200">
                {story.title}
              </h2>
            </a>

            <div className="flex items-center gap-2.5 mt-2.5 flex-wrap">
              <span className="inline-flex items-center gap-1.5 text-[11px] font-mono text-zinc-500 bg-zinc-800/60 px-2 py-0.5 rounded-md">
                <ExternalLink className="w-3 h-3" />
                {story.domain}
              </span>
              <span className="text-[11px] font-mono text-zinc-600">
                {story.author}
              </span>
              <span className="text-[11px] font-mono text-zinc-600">
                {story.relativeTime}
              </span>
              <span className="inline-flex items-center gap-1 text-[11px] font-mono text-zinc-600">
                <MessageSquare className="w-3 h-3" />
                {story.commentCount}
              </span>
            </div>
          </div>

          <button
            onClick={() => onToggleBookmark(story)}
            className={cn(
              "p-2 rounded-lg transition-all duration-200 shrink-0",
              isBookmarked
                ? "text-amber-400 bg-amber-500/10 hover:bg-amber-500/20"
                : "text-zinc-600 hover:text-zinc-300 hover:bg-zinc-800"
            )}
            aria-label={isBookmarked ? "Remove bookmark" : "Bookmark"}
          >
            {isBookmarked ? (
              <BookmarkCheck className="w-4 h-4" />
            ) : (
              <Bookmark className="w-4 h-4" />
            )}
          </button>
        </div>

        <div className="mt-4">
          <button
            onClick={handleSummarize}
            disabled={loading}
            className={cn(
              "inline-flex items-center gap-2 px-3.5 py-2 rounded-lg",
              "text-xs font-mono font-medium transition-all duration-200",
              expanded
                ? "bg-amber-500/15 text-amber-400 border border-amber-500/20"
                : "bg-zinc-800/80 text-zinc-300 hover:bg-zinc-700 hover:text-zinc-100 border border-zinc-700/50",
              loading && "opacity-60 cursor-wait"
            )}
          >
            <Sparkles
              className={cn("w-3.5 h-3.5", loading && "animate-spin-slow")}
            />
            {loading
              ? "Analyzing..."
              : expanded
              ? "Hide Summary"
              : bullets.length > 0
              ? "View Summary"
              : "Summarize"}
            {(expanded || bullets.length > 0) && !loading && (
              <ChevronDown
                className={cn(
                  "w-3 h-3 transition-transform duration-300",
                  expanded && "rotate-180"
                )}
              />
            )}
          </button>
        </div>

        <div
          className={cn(
            "grid transition-all duration-[400ms] ease-out",
            expanded
              ? "grid-rows-[1fr] opacity-100 mt-4"
              : "grid-rows-[0fr] opacity-0 mt-0"
          )}
        >
          <div className="overflow-hidden min-h-0">
            <div className="bg-zinc-950/70 border border-zinc-800/50 rounded-lg p-4">
              <p className="text-[10px] font-mono font-medium text-amber-500/60 uppercase tracking-[0.15em] mb-3 select-none">
                AI Summary
