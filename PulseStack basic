              {error ? (
                <p className="text-xs font-mono text-red-400">
                  Couldn't generate a summary. Try again.
                </p>
              ) : (
                <ul className="space-y-2.5">
                  {bullets.map((b, i) => (
                    <li
                      key={i}
                      className="flex gap-2.5 text-xs font-mono leading-relaxed text-zinc-400"
