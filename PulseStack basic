// --- MAIN APP COMPONENT ---

const titles = {
  top: "Trending",
  show: "Show HN",
  new: "New",
};

const BASE = "https://hacker-news.firebaseio.com/v0";
const endpoints = {
  top: "topstories",
  show: "showstories",
  new: "newstories",
};

export default function App() {
  const [category, setCategory] = useState("top");
  const [showBookmarks, setShowBookmarks] = useState(false);
  const [stories, setStories] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(false);
  const [sidebarOpen, setSidebarOpen] = useState(false);

  const [bmIds, setBmIds] = useState(new Set());
  const [bmStories, setBmStories] = useState([]);

  // Fetch feed directly from Firebase
  const fetchFeed = useCallback(async (cat) => {
    setLoading(true);
    setError(false);
    try {
      const endpoint = endpoints[cat] || "topstories";
      const idsRes = await fetch(`${BASE}/${endpoint}.json`);
      if (!idsRes.ok) throw new Error("Fetch failed");
      
      const ids = await idsRes.json();
      const slice = ids.slice(0, 10);
      
      const storyPromises = slice.map(async (id) => {
        const res = await fetch(`${BASE}/item/${id}.json`);
        return res.json();
      });
      
      const rawStories = await Promise.all(storyPromises);
      const processed = rawStories
        .filter((s) => s !== null && s.type === "story")
        .map(processStory);
        
      setStories(processed);
    } catch {
      setError(true);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    if (!showBookmarks) fetchFeed(category);
  }, [category, showBookmarks, fetchFeed]);

  const handleCategory = (c) => {
    setCategory(c);
    setShowBookmarks(false);
  };

  const handleShowBookmarks = () => {
    setShowBookmarks(true);
  };

  const handleToggleBookmark = (story) => {
    const isBookmarked = bmIds.has(story.id);
    let updated;
    
    if (isBookmarked) {
      updated = bmStories.filter((b) => b.id !== story.id);
    } else {
      updated = [...bmStories, story];
    }
    
    setBmIds(new Set(updated.map((b) => b.id)));
    setBmStories(updated);
  };

  const pageTitle = showBookmarks ? "Bookmarks" : titles[category];
  const display = showBookmarks ? bmStories : stories;

  return (
    <>
      {/* Inject custom styles that were present in globals.css and tailwind config */}
      <style dangerouslySetInnerHTML={{__html: `
        @import url('https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Syne:wght@400;500;600;700;800&display=swap');
        
        body {
          background: #09090b;
          color: #fafafa;
          font-family: "DM Mono", monospace;
          margin: 0;
        }

        .font-display { font-family: "Syne", sans-serif; }
        .font-mono { font-family: "DM Mono", monospace; }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #3f3f46; }

        .card-glow { transition: box-shadow 0.35s ease, border-color 0.35s ease; }
        .card-glow:hover {
          box-shadow: 0 0 40px rgba(245, 158, 11, 0.05), 0 0 80px rgba(245, 158, 11, 0.02);
          border-color: #3f3f46;
        }

        @keyframes shimmer {
          0% { background-position: -200% 0; }
          100% { background-position: 200% 0; }
        }
        .skeleton-shimmer {
          background: linear-gradient(90deg, #18181b 25%, #27272a 50%, #18181b 75%);
          background-size: 200% 100%;
          animation: shimmer 1.8s infinite;
        }

        @keyframes fadeUp {
          0% { opacity: 0; transform: translateY(14px); }
          100% { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up { animation: fadeUp 0.5s ease both; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
        .animate-spin-slow { animation: spin 1.2s linear infinite; }

        .stagger-1 { animation-delay: 0.04s; }
        .stagger-2 { animation-delay: 0.08s; }
        .stagger-3 { animation-delay: 0.12s; }
        .stagger-4 { animation-delay: 0.16s; }
        .stagger-5 { animation-delay: 0.2s; }
        .stagger-6 { animation-delay: 0.24s; }
        .stagger-7 { animation-delay: 0.28s; }
        .stagger-8 { animation-delay: 0.32s; }
        .stagger-9 { animation-delay: 0.36s; }
        .stagger-10 { animation-delay: 0.4s; }
      `}} />

      <div className="flex h-screen overflow-hidden text-zinc-100 selection:bg-amber-500/30 selection:text-amber-200">
        <Sidebar
          activeCategory={category}
          onCategoryChange={handleCategory}
          showBookmarks={showBookmarks}
          onShowBookmarks={handleShowBookmarks}
          bookmarkCount={bmStories.length}
          isOpen={sidebarOpen}
          onClose={() => setSidebarOpen(false)}
        />

        <main className="flex-1 flex flex-col overflow-hidden min-w-0">
          <Header
            onMenuClick={() => setSidebarOpen(true)}
            title={pageTitle}
          />

          <div className="flex-1 overflow-y-auto">
            <div className="max-w-3xl mx-auto px-4 py-6 lg:px-8 lg:py-8">
              <div className="flex items-end justify-between mb-6">
                <div>
                  <h2 className="font-display font-bold text-2xl text-zinc-50 tracking-tight lg:hidden">
                    {pageTitle}
                  </h2>
                  <p className="text-[11px] font-mono text-zinc-500 mt-1">
                    {showBookmarks
                      ? `${bmStories.length} saved article${bmStories.length !== 1 ? "s" : ""}`
                      : `Top 10 · Hacker News · ${pageTitle}`}
                  </p>
                </div>

                {!showBookmarks && (
                  <button
                    onClick={() => fetchFeed(category)}
                    disabled={loading}
                    className="p-2.5 rounded-lg text-zinc-500 hover:text-zinc-200 hover:bg-zinc-800 transition-colors"
                    aria-label="Refresh"
                  >
                    <RefreshCw className={cn("w-4 h-4", loading && "animate-spin-slow")} />
                  </button>
                )}
              </div>

              {/* FINISHED YOUR CUT-OFF CODE BELOW */}
              {error && (
                <div className="bg-red-500/[0.07] border border-red-500/20 rounded-xl p-5 mb-6">
                  <p className="text-sm font-mono text-red-400">
                    Failed to load stories.
                  </p>
                  <button 
                    onClick={() => fetchFeed(category)}
                    className="mt-3 px-4 py-2 bg-red-500/10 text-red-400 rounded-lg text-xs font-medium hover:bg-red-500/20 transition"
                  >
                    Try Again
                  </button>
                </div>
              )}

              {loading && !error && (
                <div className="space-y-4">
                  {Array.from({ length: 6 }).map((_, i) => (
                    <SkeletonCard key={i} />
                  ))}
                </div>
              )}

              {!loading && !error && (
                <div className="space-y-4">
                  {display.length === 0 && showBookmarks ? (
                    <div className="text-center py-20 border border-dashed border-zinc-800 rounded-xl">
                      <Bookmark className="w-8 h-8 text-zinc-600 mx-auto mb-3" />
                      <p className="text-zinc-400 text-sm">No bookmarked stories yet.</p>
                    </div>
                  ) : (
                    display.map((story, i) => (
                      <FeedCard
                        key={story.id}
                        story={story}
                        index={i}
                        isBookmarked={bmIds.has(story.id)}
                        onToggleBookmark={handleToggleBookmark}
                      />
                    ))
                  )}
                </div>
              )}
            </div>
          </div>
        </main>
      </div>
    </>
  );
}
