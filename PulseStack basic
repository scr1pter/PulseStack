    ],
  ],
};

const fallback = [
  "Examines a notable development in the tech ecosystem, contextualizing it against recent industry trends and market dynamics.",
  "Provides technical depth on the implementation details, with comparisons to alternative approaches and their trade-offs.",
  "Considers second-order effects on developer workflows, open-source communities, and the broader competitive landscape.",
];

function matchBullets(title) {
  const lower = title.toLowerCase();
  for (const [keyword, sets] of Object.entries(keywordBullets)) {
    if (lower.includes(keyword)) {
      return sets[Math.floor(Math.random() * sets.length)];
    }
  }
  return fallback;
}

async function generateSummary(storyId, title) {
  if (cache[storyId]) return cache[storyId];
  await new Promise((r) => setTimeout(r, 700 + Math.random() * 800));
  const bullets = matchBullets(title);
  cache[storyId] = bullets;
  return bullets;
}

